<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">
    <fragment
        android:id="@+id/loginFragment"
        android:name="de.glawleschkoff.scannerapp.fragment.login.LoginFragment"
        android:label="fragment_login"
        tools:layout="@layout/fragment_login" >
        <action
            android:id="@+id/action_loginFragment_to_menuFragment"
            app:destination="@id/menuFragment" />
    </fragment>
    <fragment
        android:id="@+id/menuFragment"
        android:name="de.glawleschkoff.scannerapp.fragment.menu.MenuFragment"
        android:label="fragment_menu"
        tools:layout="@layout/fragment_menu" >
        <action
            android:id="@+id/action_menuFragment_to_loginFragment"
            app:destination="@id/loginFragment" />
        <action
            android:id="@+id/action_menuFragment_to_BTZSScanFragment"
            app:destination="@id/BTZSScanFragment" />
        <action
            android:id="@+id/action_menuFragment_to_infoScanFragment2"
            app:destination="@id/infoScanFragment2" />
        <action
            android:id="@+id/action_menuFragment_to_RTEBScanFragment"
            app:destination="@id/RTEBScanFragment" />
    </fragment>
    <fragment
        android:id="@+id/BTZSScanFragment"
        android:name="de.glawleschkoff.scannerapp.fragment.btzs.BTZSScanFragment"
        android:label="fragment_btzsscan"
        tools:layout="@layout/fragment_btzsscan" >
        <action
            android:id="@+id/action_BTZSScanFragment_to_menuFragment"
            app:destination="@id/menuFragment" />
        <action
            android:id="@+id/action_BTZSScanFragment_to_BTZSSelectFragment3"
            app:destination="@id/BTZSSelectFragment3" />
        <action
            android:id="@+id/action_BTZSScanFragment_to_loginFragment"
            app:destination="@id/loginFragment" />
        <action
            android:id="@+id/action_BTZSScanFragment_self"
            app:destination="@id/BTZSScanFragment" />
    </fragment>
    <fragment
        android:id="@+id/BTZSSelectFragment3"
        android:name="de.glawleschkoff.scannerapp.fragment.btzs.BTZSSelectFragment"
        android:label="fragment_btzsselect"
        tools:layout="@layout/fragment_btzsselect" >
        <action
            android:id="@+id/action_BTZSSelectFragment3_to_BTZSScanFragment"
            app:destination="@id/BTZSScanFragment" />
        <action
            android:id="@+id/action_BTZSSelectFragment3_to_loginFragment"
            app:destination="@id/loginFragment" />
    </fragment>
    <fragment
        android:id="@+id/infoScanFragment2"
        android:name="de.glawleschkoff.scannerapp.fragment.info.InfoScanFragment"
        android:label="fragment_infoscan"
        tools:layout="@layout/fragment_infoscan" >
        <action
            android:id="@+id/action_infoScanFragment2_to_menuFragment"
            app:destination="@id/menuFragment" />
        <action
            android:id="@+id/action_infoScanFragment2_to_infoShowFragment"
            app:destination="@id/infoShowFragment" />
        <action
            android:id="@+id/action_infoScanFragment2_to_loginFragment"
            app:destination="@id/loginFragment" />
        <action
            android:id="@+id/action_infoScanFragment2_self"
            app:destination="@id/infoScanFragment2" />
    </fragment>
    <fragment
        android:id="@+id/infoShowFragment"
        android:name="de.glawleschkoff.scannerapp.fragment.info.InfoShowFragment"
        android:label="fragment_infoshow"
        tools:layout="@layout/fragment_infoshow" >
        <action
            android:id="@+id/action_infoShowFragment_to_infoScanFragment2"
            app:destination="@id/infoScanFragment2" />
        <action
            android:id="@+id/action_infoShowFragment_to_loginFragment"
            app:destination="@id/loginFragment" />
    </fragment>
    <fragment
        android:id="@+id/RTEBScanFragment"
        android:name="de.glawleschkoff.scannerapp.fragment.rteb.RTEBScanFragment"
        android:label="fragment_rtebscan"
        tools:layout="@layout/fragment_rtebscan" >
        <action
            android:id="@+id/action_RTEBScanFragment_to_menuFragment"
            app:destination="@id/menuFragment" />
        <action
            android:id="@+id/action_RTEBScanFragment_to_loginFragment"
            app:destination="@id/loginFragment" />
        <action
            android:id="@+id/action_RTEBScanFragment_to_RTEBSelectFragment"
            app:destination="@id/RTEBSelectFragment" />
        <action
            android:id="@+id/action_RTEBScanFragment_self"
            app:destination="@id/RTEBScanFragment" />
    </fragment>
    <fragment
        android:id="@+id/RTEBSelectFragment"
        android:name="de.glawleschkoff.scannerapp.fragment.rteb.RTEBSelectFragment"
        android:label="fragment_rtebselect"
        tools:layout="@layout/fragment_rtebselect" >
        <action
            android:id="@+id/action_RTEBSelectFragment_to_RTEBScanFragment"
            app:destination="@id/RTEBScanFragment" />
        <action
            android:id="@+id/action_RTEBSelectFragment_to_loginFragment"
            app:destination="@id/loginFragment" />
    </fragment>
</navigation>