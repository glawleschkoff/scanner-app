<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">
    <fragment
        android:id="@+id/info1Fragment"
        android:name="de.glawleschkoff.scannerapp.fragment.Info1Fragment"
        android:label="fragment_info1"
        tools:layout="@layout/fragment_info1" >
        <action
            android:id="@+id/action_info1Fragment_to_info2Fragment"
            app:destination="@id/info2Fragment" />
        <action
            android:id="@+id/action_info1Fragment_to_info3Fragment"
            app:destination="@id/info3Fragment" />
        <action
            android:id="@+id/action_info1Fragment_to_menuFragment"
            app:destination="@id/menuFragment" />
    </fragment>
    <fragment
        android:id="@+id/info2Fragment"
        android:name="de.glawleschkoff.scannerapp.fragment.Info2Fragment"
        android:label="fragment_info2"
        tools:layout="@layout/fragment_info2" >
        <action
            android:id="@+id/action_info2Fragment_to_info1Fragment"
            app:destination="@id/info1Fragment" />
    </fragment>
    <fragment
        android:id="@+id/info3Fragment"
        android:name="de.glawleschkoff.scannerapp.fragment.Info3Fragment"
        android:label="fragment_info3"
        tools:layout="@layout/fragment_info3" >
        <action
            android:id="@+id/action_info3Fragment_to_info1Fragment"
            app:destination="@id/info1Fragment" />
    </fragment>
    <fragment
        android:id="@+id/loginFragment"
        android:name="de.glawleschkoff.scannerapp.fragment.LoginFragment"
        android:label="fragment_login"
        tools:layout="@layout/fragment_login" >
        <action
            android:id="@+id/action_loginFragment_to_menuFragment"
            app:destination="@id/menuFragment" />
    </fragment>
    <fragment
        android:id="@+id/menuFragment"
        android:name="de.glawleschkoff.scannerapp.fragment.MenuFragment"
        android:label="fragment_menu"
        tools:layout="@layout/fragment_menu" >
        <action
            android:id="@+id/action_menuFragment_to_info1Fragment"
            app:destination="@id/info1Fragment" />
        <action
            android:id="@+id/action_menuFragment_to_loginFragment"
            app:destination="@id/loginFragment" />
    </fragment>
</navigation>